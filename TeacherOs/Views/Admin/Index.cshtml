@using TeacherOs.Core
@using TeacherOs.DTO

@{
    ViewData["Title"] = "Admin Dashboard";
    var students = ViewData["Students"] as PaginatedResult<UserReadOnlyDTO>;
    var teachers = ViewData["Teachers"] as PaginatedResult<UserReadOnlyDTO>;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Admin Dashboard</h1>
        <div class="d-flex align-items-center gap-3">
            <div class="text-muted">Welcome, @User?.Identity!.Name!</div>
            <form asp-controller="User" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                </button>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 py-2 border-start border-primary border-4">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Teachers</div>
                    <div class="h5 mb-0 font-weight-bold">@(teachers?.TotalRecords ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card shadow h-100 py-2 border-start border-success border-4">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Students</div>
                    <div class="h5 mb-0 font-weight-bold">@(students?.TotalRecords ?? 0)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Signup", "Student")" class="btn btn-outline-success me-2">
                        <i class="fas fa-user-graduate me-1"></i>Add Student
                    </a>
                    <a href="@Url.Action("Signup", "Teacher")" class="btn btn-outline-primary me-2">
                        <i class="fas fa-chalkboard-teacher me-1"></i>Add Teacher
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">Students</h6>
                </div>
                <div class="card-body">
                    @if (students != null && students.Data.Any())
                    {
                        <table class="table table-bordered table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Id</th>
                                    <th>Username</th>
                                    <th>Firstname</th>
                                    <th>Lastname</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in students.Data)
                                {
                                    <tr>
                                        <td>@student.Id</td>
                                        <td>@student.Username</td>
                                        <td>@student.Firstname</td>
                                        <td>@student.Lastname</td>
                                        <td>@student.Email</td>
                                        <td>@student.UserRole</td>
                                        <td>
                                            <a asp-controller="Admin" asp-action="EditUser"
                                               asp-route-id="@student.Id"
                                               class="btn btn-warning btn-sm">Edit</a>
                                            <form asp-controller="Admin" asp-action="DeleteStudent" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@student.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Delete this student?')">
                                                    Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No students found.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Teachers</h6>
                </div>
                <div class="card-body">
                    @if (teachers != null && teachers.Data.Any())
                    {
                        <table class="table table-bordered table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Id</th>
                                    <th>Username</th>
                                    <th>Firstname</th>
                                    <th>Lastname</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teacher in teachers.Data)
                                {
                                    <tr>
                                        <td>@teacher.Id</td>
                                        <td>@teacher.Username</td>
                                        <td>@teacher.Firstname</td>
                                        <td>@teacher.Lastname</td>
                                        <td>@teacher.Email</td>
                                        <td>@teacher.UserRole</td>
                                        <td>
                                            <a asp-controller="Admin" asp-action="EditUser"
                                               asp-route-id="@teacher.Id"
                                               class="btn btn-warning btn-sm">Edit</a>
                                            <form asp-controller="Admin" asp-action="DeleteTeacher" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@teacher.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Delete this teacher?')">
                                                    Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No teachers found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>