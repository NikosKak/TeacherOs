@{
    ViewData["Title"] = "Student Dashboard";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Student Dashboard</h1>
        <div class="d-flex align-items-center gap-3">
            <div class="text-muted">Welcome back, @User?.Identity!.Name!</div>
            <form asp-controller="User" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                </button>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <i class="fas fa-book fa-2x text-primary mb-2"></i>
                    <h5>Enrolled Courses</h5>
                    <h3 class="text-primary">5</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <i class="fas fa-tasks fa-2x text-success mb-2"></i>
                    <h5>Pending Assignments</h5>
                    <h3 class="text-success">3</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <i class="fas fa-chart-line fa-2x text-info mb-2"></i>
                    <h5>Current GPA</h5>
                    <h3 class="text-info">3.75</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-calendar-day me-2"></i>Today's Classes</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Course</th>
                                    <th>Room</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>9:00 AM</td>
                                    <td>Mathematics 101</td>
                                    <td>Room 201</td>
                                </tr>
                                <tr>
                                    <td>11:00 AM</td>
                                    <td>Computer Science</td>
                                    <td>Lab A</td>
                                </tr>
                                <tr>
                                    <td>2:00 PM</td>
                                    <td>Physics</td>
                                    <td>Room 305</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-exclamation-circle me-2"></i>Upcoming Deadlines</h6>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Math Homework #5</h6>
                                <small class="text-danger">Due Tomorrow</small>
                            </div>
                            <p class="mb-1">Calculus problems chapter 3</p>
                            <small>Mathematics 101</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Programming Project</h6>
                                <small class="text-warning">Due in 3 days</small>
                            </div>
                            <p class="mb-1">Web API development</p>
                            <small>Computer Science</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Physics Lab Report</h6>
                                <small class="text-info">Due next week</small>
                            </div>
                            <p class="mb-1">Experiment analysis</p>
                            <small>Physics</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>